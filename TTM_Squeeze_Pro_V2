# TTM_Squeeze_Pro_V2
#
# Modificado para mostrar tres niveles de compresión:
# - Gris: Sin squeeze
# - Naranja Oscuro: Pre-squeeze (compresión baja)
# - Amarillo: Squeeze original (compresión media)
# - Rojo: Squeeze extremo (compresión alta)
#
# El histograma muestra el momentum:
# - Verde claro: Momentum positivo creciente
# - Verde oscuro: Momentum positivo decreciente
# - Rojo: Momentum negativo creciente
# - Rojo oscuro: Momentum negativo decreciente

declare lower;

# ==================== INPUTS CONFIGURABLES ====================
input price = close;
input length = 20;
input Num_Dev_Dn = -2.0;
input Num_Dev_up = 2.0;
input averageType = AverageType.SIMPLE;
input displace = 0;

# Factores para Keltner Channels (múltiples niveles)
input squeezeLevelLow = 1.0;      # Pre-squeeze - compresión baja
input squeezeLevelMid = 1.5;      # Squeeze original - compresión media
input squeezeLevelHigh = 2.0;     # Squeeze extremo - compresión alta
input trueRangeAverageType = AverageType.SIMPLE;

# Configuración de alertas (1 = activado, 0 = desactivado)
input alertOnSqueezeRelease = 1;
input alertOnMomentumFlip = 1;
input alertOnExtremeSqueeze = 1;

# ==================== BOLLINGER BANDS ====================
def sDev = StDev(data = price[-displace], length = length);
def MidLineBB = MovingAverage(averageType, data = price[-displace], length = length);
def LowerBandBB = MidLineBB + Num_Dev_Dn * sDev;
def UpperBandBB = MidLineBB + Num_Dev_up * sDev;

# ==================== KELTNER CHANNELS (TRES NIVELES) ====================
def shiftLow = squeezeLevelLow * MovingAverage(trueRangeAverageType, TrueRange(high, close, low), length);
def shiftMid = squeezeLevelMid * MovingAverage(trueRangeAverageType, TrueRange(high, close, low), length);
def shiftHigh = squeezeLevelHigh * MovingAverage(trueRangeAverageType, TrueRange(high, close, low), length);
def average = MovingAverage(averageType, price, length);

def Avg = average[-displace];

# Keltner Channels - Nivel Bajo (Pre-squeeze)
def UpperBandKCLow = average[-displace] + shiftLow[-displace];
def LowerBandKCLow = average[-displace] - shiftLow[-displace];

# Keltner Channels - Nivel Medio (Squeeze original)
def UpperBandKCMid = average[-displace] + shiftMid[-displace];
def LowerBandKCMid = average[-displace] - shiftMid[-displace];

# Keltner Channels - Nivel Alto (Squeeze extremo)
def UpperBandKCHigh = average[-displace] + shiftHigh[-displace];
def LowerBandKCHigh = average[-displace] - shiftHigh[-displace];

# ==================== CÁLCULO DEL MOMENTUM ====================
def K = (Highest(high, length) + Lowest(low, length)) / 2 + ExpAverage(close, length);
def momo = Inertia(price - K / 2, length);

# ==================== CONDICIONES DE MOMENTUM ====================
def pos = momo >= 0;
def neg = momo < 0;
def up = momo >= momo[1];
def dn = momo < momo[1];

# ==================== TRES NIVELES DE SQUEEZE ====================
def presqueeze = LowerBandBB > LowerBandKCLow and UpperBandBB < UpperBandKCLow;
def originalSqueeze = LowerBandBB > LowerBandKCMid and UpperBandBB < UpperBandKCMid;
def ExtrSqueeze = LowerBandBB > LowerBandKCHigh and UpperBandBB < UpperBandKCHigh;

# ==================== COMBINACIONES DE MOMENTUM ====================
def PosUp = pos and up;
def PosDn = pos and dn;
def NegDn = neg and dn;
def NegUp = neg and up;

# ==================== ALERTAS ====================
# Alerta cuando termina un squeeze extremo
def squeezeReleased = !ExtrSqueeze and ExtrSqueeze[1];
Alert(alertOnSqueezeRelease and squeezeReleased, "SQUEEZE EXTREMO LIBERADO", Alert.BAR, Sound.Chimes);

# Alerta de cambio en el momentum
def momentumFlip = (pos and !pos[1]) or (!pos and pos[1]);
Alert(alertOnMomentumFlip and momentumFlip, "CAMBIO DE MOMENTUM", Alert.BAR, Sound.Bell);

# Alerta cuando se forma un squeeze extremo nuevo
def newExtremeSqueeze = ExtrSqueeze and !ExtrSqueeze[1];
Alert(alertOnExtremeSqueeze and newExtremeSqueeze, "NUEVO SQUEEZE EXTREMO", Alert.BAR, Sound.Ding);

# ==================== PLOT 1: LÍNEA DE SQUEEZE (puntos en cero) ====================
plot squeezeline = 0;
squeezeline.SetPaintingStrategy(PaintingStrategy.POINTS);
squeezeline.SetLineWeight(3);
squeezeline.AssignValueColor(if ExtrSqueeze then Color.RED 
    else if originalSqueeze then Color.YELLOW 
    else if presqueeze then Color.DARK_ORANGE 
    else Color.GRAY);

# ==================== PLOT 2: HISTOGRAMA DE MOMENTUM ====================
plot momentum = momo;
momentum.SetPaintingStrategy(PaintingStrategy.HISTOGRAM);
momentum.SetLineWeight(3);
momentum.AssignValueColor(if PosUp then Color.GREEN 
    else if PosDn then Color.DARK_GREEN 
    else if NegDn then Color.RED 
    else if NegUp then Color.DARK_RED 
    else Color.YELLOW);

# ==================== PLOT 3: LÍNEA CENTRAL ====================
plot cero = 0;
cero.SetDefaultColor(Color.GRAY);
cero.SetStyle(Curve.LONG_DASH);

# ==================== ETIQUETAS INFORMATIVAS ====================
# Etiqueta del estado actual del squeeze
AddLabel(yes, 
    if ExtrSqueeze then "EXTREME SQUEEZE" 
    else if originalSqueeze then "SQUEEZE" 
    else if presqueeze then "PRE-SQUEEZE" 
    else "NO SQUEEZE",
    if ExtrSqueeze then Color.RED 
    else if originalSqueeze then Color.YELLOW 
    else if presqueeze then Color.DARK_ORANGE 
    else Color.GRAY);

# Etiqueta del momentum actual
AddLabel(yes, 
    if PosUp then "MOMENTUM POSITIVO ↑" 
    else if PosDn then "MOMENTUM POSITIVO ↓" 
    else if NegDn then "MOMENTUM NEGATIVO ↓" 
    else if NegUp then "MOMENTUM NEGATIVO ↑" 
    else "NEUTRO",
    if PosUp or PosDn then Color.GREEN 
    else if NegDn or NegUp then Color.RED 
    else Color.GRAY);

# TTM_Squeeze_Pro
#
# Modificado para mostrar tres niveles de compresión:
# - Gris: Sin squeeze
# - Naranja Oscuro: Pre-squeeze (compresión baja)
# - Amarillo: Squeeze original (compresión media)
# - Rojo: Squeeze extremo (compresión alta)
#
# El histograma muestra el momentum:
# - Verde claro: Momentum positivo creciente
# - Verde oscuro: Momentum positivo decreciente
# - Rojo: Momentum negativo creciente
# - Rojo oscuro: Momentum negativo decreciente

declare lower;

input price = close;
input length = 20;
input Num_Dev_Dn = -2.0;
input Num_Dev_up = 2.0;
input averageType = AverageType.SIMPLE;
input displace = 0;

# Bollinger Bands
def sDev = StDev(data = price[-displace], length = length);
def MidLineBB = MovingAverage(averageType, data = price[-displace], length = length);
def LowerBandBB = MidLineBB + Num_Dev_Dn * sDev;
def UpperBandBB = MidLineBB + Num_Dev_up * sDev;

# Factores para Keltner Channels (múltiples niveles)
input factorhigh = 1.0;
input factormid = 1.5;
input factorlow = 2.0;
input trueRangeAverageType = AverageType.SIMPLE;

def shifthigh = factorhigh * MovingAverage(trueRangeAverageType, TrueRange(high, close, low), length);
def shiftMid = factormid * MovingAverage(trueRangeAverageType, TrueRange(high, close, low), length);
def shiftlow = factorlow * MovingAverage(trueRangeAverageType, TrueRange(high, close, low), length);
def average = MovingAverage(averageType, price, length);

def Avg = average[-displace];

# Keltner Channels para tres niveles de squeeze
def UpperBandKCLow = average[-displace] + shiftlow[-displace];
def LowerBandKCLow = average[-displace] - shiftlow[-displace];

def UpperBandKCMid = average[-displace] + shiftMid[-displace];
def LowerBandKCMid = average[-displace] - shiftMid[-displace];

def UpperBandKCHigh = average[-displace] + shifthigh[-displace];
def LowerBandKCHigh = average[-displace] - shifthigh[-displace];

# Cálculo del momentum (Mobius)
def K = (Highest(high, length) + Lowest(low, length)) / 2 + ExpAverage(close, length);
def momo = Inertia(price - K / 2, length);

# Condiciones de momentum
def pos = momo >= 0;
def neg = momo < 0;
def up = momo >= momo[1];
def dn = momo < momo[1];

# Tres niveles de squeeze (la innovación del Squeeze Pro)
def presqueeze = LowerBandBB > LowerBandKCLow and UpperBandBB < UpperBandKCLow;
def originalSqueeze = LowerBandBB > LowerBandKCMid and UpperBandBB < UpperBandKCMid;
def ExtrSqueeze = LowerBandBB > LowerBandKCHigh and UpperBandBB < UpperBandKCHigh;

# Combinaciones de momentum para colorear el histograma
def PosUp = pos and up;
def PosDn = pos and dn;
def NegDn = neg and dn;
def NegUp = neg and up;

# PLOT 1: Línea de squeeze (puntos en cero)
plot squeezeline = 0;
squeezeline.SetPaintingStrategy(PaintingStrategy.POINTS);
squeezeline.SetLineWeight(3);
squeezeline.AssignValueColor(if ExtrSqueeze then Color.RED 
    else if originalSqueeze then Color.YELLOW 
    else if presqueeze then Color.MAGENTA 
    else Color.GRAY);

# PLOT 2: Histograma de momentum
plot momentum = momo;
momentum.SetPaintingStrategy(PaintingStrategy.HISTOGRAM);
momentum.SetLineWeight(3);
momentum.AssignValueColor(if PosUp then Color.GREEN 
    else if PosDn then Color.DARK_GREEN 
    else if NegDn then Color.RED 
    else if NegUp then Color.DARK_RED 
    else Color.YELLOW);

# Línea central
plot cero = 0;
cero.SetDefaultColor(Color.GRAY);
cero.SetStyle(Curve.LONG_DASH);
